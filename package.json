{
  "name": "@quadslab.io/discord-mcp",
  "version": "2.0.0",
  "description": "Manage your entire Discord server from Claude Code, Claude Desktop, Cursor, or Windsurf via MCP. 134 admin tools across 20 categories. Interactive setup wizard included.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js",
    "./server": "./dist/mcp-server.js"
  },
  "bin": {
    "discord-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "npx tsx src/cli.ts"
  },
  "keywords": [
    "discord",
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "claude-desktop",
    "cursor",
    "windsurf",
    "server-admin",
    "discord-bot",
    "discord-management",
    "discord-admin",
    "anthropic",
    "ai-tools"
  ],
  "author": "QuadsLab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HardHeadHackerHead/discord-mcp"
  },
  "homepage": "https://github.com/HardHeadHackerHead/discord-mcp#readme",
  "bugs": {
    "url": "https://github.com/HardHeadHackerHead/discord-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
